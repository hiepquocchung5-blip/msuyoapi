# ============================================================================
# SUROPARA BACKEND - AAA SECURITY GATEWAY (.htaccess)
# ============================================================================

# 1. Disable Directory Browsing (Critical Security)
Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On

    # 2. Force HTTPS
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # 3. Authorization Header Pass-Through (CRITICAL FIX)
    # Apache strips Bearer tokens by default. This forces it into the PHP environment.
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # 4. Strip .php Extensions (Legacy Support / Fallback)
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}\.php -f
    RewriteRule ^(.*)$ $1.php [L]

    # 5. Protect Internal Architecture
    # Instantly throw a 403 Forbidden if anyone tries to directly access core folders
    RewriteRule ^(api/config|api/utils|cron|utils|config)/.*$ - [F,L]
</IfModule>

# 6. Strict CORS Headers (Restored to proven working logic)
<IfModule mod_headers.c>
    # STRICTLY locked to the exact domain (no www) and local dev
    SetEnvIf Origin "^https://suropara\.com$" AccessControlAllowOrigin=$0
    SetEnvIf Origin "^http://localhost:3000$" AccessControlAllowOrigin=$0
    
    Header always set Access-Control-Allow-Origin %{AccessControlAllowOrigin}e env=AccessControlAllowOrigin
    Header always set Access-Control-Allow-Methods "POST, GET, OPTIONS, PUT, DELETE"
    Header always set Access-Control-Allow-Headers "Content-Type, Authorization, X-Requested-With, Idempotency-Key"
    Header always set Access-Control-Allow-Credentials "true"
    
    # Handle Preflight OPTIONS requests instantly without hitting PHP
    RewriteCond %{REQUEST_METHOD} OPTIONS
    RewriteRule ^(.*)$ $1 [R=200,L]
</IfModule>

# 7. Protect Core Utility Files & Configs
# Prevents direct URL access to your environment variables and middleware
<FilesMatch "(\.env|\.git|\.sql|\.md|database\.php|auth_middleware\.php|admin_middleware\.php|security\.php|env_loader\.php)$">
    Require all denied
</FilesMatch>